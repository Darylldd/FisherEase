<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Fish Species</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="#">FMO Admin</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/dashboard/admin">Dashboard</a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Register</a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/register/fisherfolk">Fisherfolk Registration</a></li>
              <li><a class="dropdown-item" href="/aquaculture/register">Aquaculture Facility Registration</a></li>
            </ul>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Reports & Tracking</a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/catch-report/review">Catch Report Review</a></li>
              <li><a class="dropdown-item" href="/fishing-activity-log">Fishing Activity Tracking</a></li>
              <li><a class="dropdown-item" href="/enforcement-compliance-logging">Enforcement and Compliance Logging</a></li>
              <li><a class="dropdown-item" href="/violation-notifications">Violation Notification System</a></li>
              <li><a class="dropdown-item" href="/audit/logs">Audit Logs & Activity Tracking</a></li>
              <li><a class="dropdown-item" href="/harvest/admin-view">Harvest & Production Data Entry</a></li>
              <li><a class="dropdown-item" href="/fish-species">Fish Species Guide</a></li>
              <li><a class="dropdown-item" href="/admin/fish-species/add">➕ Add Fish Species</a></li>
            </ul>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Tools</a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/catch-report/admin/report">Generate Catch Report</a></li>
              <li><a class="dropdown-item" href="#">Gov Reports</a></li>
              <li><a class="dropdown-item" href="/climate-analysis">Climate Event Analysis</a></li>
            </ul>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#">Welcome, <%= user.name %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#logoutModal">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Logout Modal -->
  <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Confirm Logout</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">Are you sure you want to log out?</div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <a href="/auth/logout" class="btn btn-danger">Logout</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Add Fish Species Form -->
  <div class="container mt-4">
    <h2>Add Fish Species</h2>
    <form action="/admin/fish-species/add" method="POST" enctype="multipart/form-data">
      <div class="mb-3">
        <label for="common_name" class="form-label">Common Name</label>
        <input type="text" class="form-control" id="common_name" name="common_name" required>
      </div>

      <div class="mb-3">
        <label for="scientific_name" class="form-label">Scientific Name</label>
        <input type="text" class="form-control" id="scientific_name" name="scientific_name" required>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea class="form-control" id="description" name="description" required></textarea>
      </div>

      <div class="mb-3">
        <label for="habitat" class="form-label">Habitat</label>
        <textarea class="form-control" id="habitat" name="habitat"></textarea>
      </div>

      <div class="mb-3">
        <label for="fishing_method" class="form-label">Fishing Method</label>
        <textarea class="form-control" id="fishing_method" name="fishing_method"></textarea>
      </div>

      <div class="mb-3">
        <label for="regulations" class="form-label">Regulations</label>
        <textarea class="form-control" id="regulations" name="regulations"></textarea>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Image</label>
        <input type="file" class="form-control" id="image" name="image" accept="image/*">
      </div>

      <button type="submit" class="btn btn-primary">Add Species</button>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
